ORACLE_USER=seu_usuario_aqui
ORACLE_PASSWORD=sua_senha_aqui
ORACLE_DSN=ip_do_banco:1521/nome_do_servico_aqui

# Caminho para o arquivo de credenciais do Firebase (service account JSON)
# Obtenha em: Firebase Console → Configurações do projeto → Contas de serviço → Gerar nova chave privada
# NÃO commite este arquivo no git — mantenha-o apenas localmente na máquina de execução
FIREBASE_CREDENTIALS_PATH=/caminho/absoluto/para/firebase_credentials.json
